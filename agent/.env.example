# ── Plaid API ─────────────────────────────────────────────────────────────────
# Get credentials from: https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_production_secret
PLAID_ENV=production

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and service-role key (NOT the anon key) from:
# https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── Email notifications (SendGrid) ────────────────────────────────────────────
# Optional — skip if you don't want email alerts
# Create a free account + verified sender at: https://app.sendgrid.com/
SENDGRID_API_KEY=SG.xxxxxx
SENDGRID_FROM_EMAIL=your-verified-sender@example.com
NOTIFICATION_EMAIL=you@example.com

# ── Slack notifications (optional) ────────────────────────────────────────────
# Create an incoming webhook at: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# ── Pushover notifications (optional) ─────────────────────────────────────────
# https://pushover.net/
# PUSHOVER_USER_KEY=your_user_key
# PUSHOVER_APP_TOKEN=your_app_token
